{
   "extends": "../../packages/typescript-config/base.json",

  "compilerOptions": {
     "baseUrl": ".",
      "paths": {
      "@/*": ["src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true, "allowSyntheticDefaultImports": true
  },
  "include": ["src"]
}