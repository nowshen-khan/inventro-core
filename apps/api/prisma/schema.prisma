// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  //  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  DAMAGE
  ADJUSTMENT
}

enum Gender {
  MALE
  FEMALE
  UNISEX
  BOYS
  GIRLS
  KIDS
}

model User {
  id         String  @id @default(uuid())
  email      String  @unique
  password   String
  name       String
  roleId     String
  role       Role    @relation(fields: [roleId], references: [id])
  locationId String?

  location Location? @relation(fields: [locationId], references: [id])

  refreshToken String?

  auditLogs AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
}

model Permission {
  id     String @id @default(uuid())
  action String @unique

  roles RolePermission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

enum LocationType {
  WAREHOUSE
  OUTLET
  TRANSIT
}

model Location {
  id String @id @default(uuid())

  name String
  code String @unique

  type LocationType

  address String?

  isActive Boolean @default(true)

  parentId String?

  parent Location? @relation("LocationHierarchy", fields: [parentId], references: [id])

  children Location[] @relation("LocationHierarchy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users User[]

  purchases       Purchase[]
  purchaseReturns PurchaseReturn[]

  sales       Sale[]
  saleReturns SaleReturn[]

  expenses Expense[]

  productExchanges ProductExchange[]

  stockAdjustments StockAdjustment[]

  stocks Stock[]

  sourceTransfers Transfer[] @relation("source")
  destTransfers   Transfer[] @relation("dest")

  @@index([type])
  @@index([deletedAt])
}

model Product {
  id String @id @default(uuid())

  name        String
  styleCode   String           @unique
  description String?
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?           @relation(fields: [brandId], references: [id])
  supplierId  String?
  supplier    Supplier?        @relation(fields: [supplierId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
}

model ProductVariant {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  sku String @unique

  barcode String? @unique

  color String?

  size String?

  gender Gender?

  costPrice Decimal @db.Money

  sellingPrice Decimal @db.Money

  reorderLevel Int @default(10)

  stocks               Stock[]
  stockAdjustmentItems StockAdjustmentItem[]

  purchaseItems       PurchaseItem[]
  purchaseReturnItems PurchaseReturnItem[]

  saleItems     SaleItem[]
  transferItems TransferItem[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  SaleReturnItem SaleReturnItem[]
}

model ProductImage {
  id        String    @id @default(uuid())
  url       String
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ProductExchange {
  id String @id @default(uuid())

  exchangeNo String @unique

  originalSaleId String
  originalSale   Sale   @relation(fields: [originalSaleId], references: [id])

  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])

  newSaleId String
  newSale   Sale   @relation("ExchangeNewSale", fields: [newSaleId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  locationId String

  location Location @relation(fields: [locationId], references: [id])

  exchangeAmount Decimal @default(0) @db.Money

  refundAmount Decimal @default(0) @db.Money

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  description String?

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Brand {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Supplier {
  id        String     @id @default(uuid())
  name      String
  email     String?    @unique
  phone     String?    @unique
  address   String?
  products  Product[]
  purchases Purchase[]

  purchaseReturns PurchaseReturn[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Customer {
  id      String  @id @default(uuid())
  name    String
  email   String? @unique
  phone   String? @unique
  address String?

  sales          Sale[]
  lastPurchaseAt DateTime?
  totalSpent     Decimal   @default(0)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  SaleReturn      SaleReturn[]
  ProductExchange ProductExchange[]
}

model Stock {
  id String @id @default(uuid())

  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  quantity         Int @default(0)
  reservedQuantity Int @default(0)

  movements StockMovement[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([productVariantId, locationId])
}

model StockMovement {
  id            String       @id @default(uuid())
  stockId       String
  stock         Stock        @relation(fields: [stockId], references: [id])
  type          MovementType
  quantity      Int
  referenceType String? // e.g., "Sale", "Purchase", "Transfer"
  referenceId   String?
  note          String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

enum AdjustmentReason {
  DAMAGE
  MISSING
  FOUND
  PHYSICAL_COUNT
  SAMPLE
}

model StockAdjustment {
  id String @id @default(uuid())

  adjustmentNo String @unique

  locationId String

  location Location @relation(fields: [locationId], references: [id])

  reason AdjustmentReason
  note   String?

  createdBy String

  items StockAdjustmentItem[]

  createdAt DateTime @default(now())
}

model StockAdjustmentItem {
  id String @id @default(uuid())

  stockAdjustmentId String
  stockAdjustment   StockAdjustment @relation(fields: [stockAdjustmentId], references: [id])

  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])

  systemQuantity Int

  physicalQuantity Int

  difference Int
}

model Purchase {
  id         String   @id @default(uuid())
  invoiceNo  String   @unique
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  purchaseReturns PurchaseReturn[]

  locationId String

  location Location @relation(fields: [locationId], references: [id])

  items       PurchaseItem[]
  totalAmount Decimal        @db.Money
  paidAmount  Decimal        @default(0) @db.Money
  dueDate     DateTime?
  status      PurchaseStatus @default(PENDING)
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL_RECEIVED
  CANCELLED
}

model PurchaseItem {
  id               String         @id @default(uuid())
  purchaseId       String
  purchase         Purchase       @relation(fields: [purchaseId], references: [id])
  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  costPrice        Decimal        @db.Money
  totalPrice       Decimal        @db.Money

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model PurchaseReturn {
  id String @id @default(uuid())

  returnNo String @unique

  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  totalAmount Decimal @db.Money

  note String?

  items PurchaseReturnItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model PurchaseReturnItem {
  id String @id @default(uuid())

  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])

  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])

  quantity Int

  costPrice Decimal @db.Money

  totalPrice Decimal @db.Money

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Sale {
  id        String @id @default(uuid())
  invoiceNo String @unique

  locationId String

  location Location @relation(fields: [locationId], references: [id])

  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  items      SaleItem[]

  saleReturns SaleReturn[]

  exchangeSales ProductExchange[] @relation("ExchangeNewSale")

  subtotal        Decimal           @db.Money
  tax             Decimal           @default(0) @db.Money
  discount        Decimal           @default(0) @db.Money
  totalAmount     Decimal           @db.Money
  paidAmount      Decimal           @default(0) @db.Money
  paymentMethod   String? // CASH, CARD, etc.
  status          SaleStatus        @default(COMPLETED)
  createdBy       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  ProductExchange ProductExchange[]
}

enum SaleStatus {
  COMPLETED
  REFUNDED
}

model SaleItem {
  id               String         @id @default(uuid())
  saleId           String
  sale             Sale           @relation(fields: [saleId], references: [id])
  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  sellingPrice     Decimal        @db.Money
  totalPrice       Decimal        @db.Money

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model SaleReturn {
  id String @id @default(uuid())

  returnNo String @unique

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  totalAmount Decimal @db.Money

  refundAmount Decimal @default(0) @db.Money

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items           SaleReturnItem[]
  ProductExchange ProductExchange[]
}

model SaleReturnItem {
  id String @id @default(uuid())

  saleReturnId String
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])

  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])

  quantity Int

  sellingPrice Decimal @db.Money

  totalPrice Decimal @db.Money

  createdAt DateTime @default(now())
}

model Transfer {
  id               String   @id @default(uuid())
  transferNo       String   @unique
  sourceLocationId String
  sourceLocation   Location @relation("source", fields: [sourceLocationId], references: [id])

  destLocationId String
  destLocation   Location       @relation("dest", fields: [destLocationId], references: [id])
  items          TransferItem[]
  status         TransferStatus @default(PENDING)
  note           String?
  requestedBy    String?
  approvedBy     String?
  requestedDate?: string;
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
}

enum TransferStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model TransferItem {
  id               String         @id @default(uuid())
  transferId       String
  transfer         Transfer       @relation(fields: [transferId], references: [id])
  productVariantId String
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Expense {
  id          String  @id @default(uuid())
  description String
  amount      Decimal @db.Money

  locationId String?

  location Location? @relation(fields: [locationId], references: [id])

  date      DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model AuditLog {
  id       String  @id @default(uuid())
  action   String
  entity   String
  entityId String?
  oldValue Json?
  newValue Json?
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  ip       String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}
